# =====================================================
# Project Socrates - Environment Variables
# =====================================================
# Copy this file to .env.local and fill in your values

# =====================================================
# Supabase Configuration
# =====================================================
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =====================================================
# AI Models - DeepSeek (Logic/Chat)
# =====================================================
AI_BASE_URL_LOGIC=https://api.deepseek.com/v1
AI_API_KEY_LOGIC=sk-deepseek-api-key

# =====================================================
# AI Models - Qwen (Vision/OCR)
# =====================================================
AI_BASE_URL_VISION=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_API_KEY_VISION=sk-qwen-api-key

# =====================================================
# App Configuration
# =====================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Socrates

# =====================================================
# Optional provider compatibility
# =====================================================
AI_MODEL_LOGIC=qwen-plus
DASHSCOPE_API_KEY=

# =====================================================
# Phone auth - local default
# =====================================================
PHONE_AUTH_SMS_PROVIDER=console
AUTH_CODE_EXPIRES_MINUTES=10
AUTH_CODE_RESEND_COOLDOWN_SECONDS=60
AUTH_CODE_MAX_ATTEMPTS_PER_10_MIN=5
AUTH_CODE_MAX_ATTEMPTS_PER_IP_10_MIN=12

# Tencent SMS (recommended primary provider)
TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=
TENCENT_SMS_REGION=ap-guangzhou
# JSON array, placeholders: {{code}} {{expiryMinutes}} {{phone}} {{message}}
TENCENT_SMS_TEMPLATE_PARAMS_JSON=["{{code}}","{{expiryMinutes}}"]
TENCENT_SMS_SESSION_CONTEXT_PREFIX=phone-auth

# Aliyun SMS (recommended fallback provider)
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
# JSON object, placeholders: {{code}} {{expiryMinutes}} {{phone}} {{message}}
ALIYUN_SMS_TEMPLATE_PARAMS_JSON={"code":"{{code}}","minutes":"{{expiryMinutes}}"}
ALIYUN_SMS_OUT_ID_PREFIX=phone-auth

# =====================================================
# Optional WeChat integration
# =====================================================
WECHAT_APP_ID=
WECHAT_APP_SECRET=
