# =====================================================
# Project Socrates - Environment Variables
# =====================================================
# Copy this file to .env.local and fill in your values

# =====================================================
# Supabase Configuration
# =====================================================
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =====================================================
# AI Models - DeepSeek (Logic/Chat)
# =====================================================
AI_BASE_URL_LOGIC=https://api.deepseek.com/v1
AI_API_KEY_LOGIC=sk-deepseek-api-key

# =====================================================
# AI Models - Qwen (Vision/OCR)
# =====================================================
AI_BASE_URL_VISION=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_API_KEY_VISION=sk-qwen-api-key

# =====================================================
# App Configuration
# =====================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Socrates
