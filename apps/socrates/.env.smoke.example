# =====================================================
# Project Socrates - Smoke Environment Variables
# =====================================================
# Copy this file to .env.smoke.local and fill in disposable test accounts.

# =====================================================
# Shared smoke runtime
# =====================================================
SMOKE_BASE_URL=http://localhost:3000

# =====================================================
# Standard Socrates smoke
# =====================================================
SMOKE_USER_ID=
SMOKE_PARENT_ID=
SMOKE_CHILD_ID=
SMOKE_COUPON_CODE=WELCOME10
SMOKE_PLAN_CODE=pro_monthly
SMOKE_PAYMENT_METHOD=alipay
SMOKE_CREATE_ORDER=false

# =====================================================
# Study / report / review smoke
# =====================================================
SMOKE_STUDY_USER_ID=
SMOKE_STUDY_SUBJECT=english
SMOKE_STUDY_MODULE=writing-review
SMOKE_STUDY_QUESTION_TYPE=writing
SMOKE_STUDY_REPORT_DAYS=7
SMOKE_STUDY_ADVANCE_REVIEW=false
